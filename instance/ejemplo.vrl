defmodule Set
  using List
  defspace Set < SuperSet end
  
  defoperator union(Set, Set) end
  defoperator isIn(Element, Set) end
  defoperator implication(Bool, Bool) end
  defoperator negation(Bool) end
  
  defvar p: Bool, q: Bool end
  
  defrule (implication(p, q)) -> (disjunction(negation(p), q)) end
  
  defexpression 
    (forall x in Element . (forall S in Set . (forall U in Set . (x isIn (S union U)) ≡ ((x isIn S) or (x in U))))) 
  end
end